{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "amendment",
  "type": "object",
  "required": ["id", "title", "proposed_by", "target", "reason", "proposed_change", "rollback"],
  "properties": {
    "id": {"type": "string", "pattern": "^A-[0-9]{4}$"},
    "title": {"type": "string", "minLength": 1},
    "proposed_by": {
      "type": "object",
      "required": ["actor", "office"],
      "properties": {
        "actor": {"type": "string"},
        "office": {"type": "string"}
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file": {"type": "string"},
        "section": {"type": "string"}
      },
      "additionalProperties": false
    },
    "reason": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "proposed_change": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {"type": "string"},
        "to": {"type": "string"}
      },
      "additionalProperties": false
    },
    "rollback": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
